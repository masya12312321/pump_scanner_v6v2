# Скопируйте этот файл в .env и заполните своими значениями.
# На Render эти же переменные задаются в Dashboard → Environment,
# файл .env туда заливать не нужно (он в .gitignore).

BOT_TOKEN=ваш_токен_от_BotFather
CHAT_ID=ваш_telegram_chat_id
HELIUS_KEY=ваш_helius_api_key
DB_PATH=pump_scanner.db
LOG_LEVEL=INFO

# Только для РЕАЛЬНОЙ автоторговли (/paper off). В paper-режиме не нужен.
# Базовая58-строка приватного ключа (как при экспорте кошелька из Phantom).
# НИКОГДА не коммитьте этот файл с реальным ключом в git.
WALLET_PRIVATE_KEY=
